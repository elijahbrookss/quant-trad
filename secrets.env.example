# Copy this file to `secrets.env` and fill in your private credentials.
# This file is used by the trading engine and Docker services to authenticate
# against Alpaca. The actual `secrets.env` file is git-ignored so your keys
# remain local.

ALPACA_API_KEY=replace-with-your-key
ALPACA_SECRET_KEY=replace-with-your-secret

# Optional CCXT credentials. Define global keys or per-exchange overrides
# (e.g. CCXT_BINANCE_API_KEY) for venues that require authentication.
CCXT_API_KEY=
CCXT_API_SECRET=
CCXT_PASSWORD=
# Per-exchange overrides (uncomment as needed)
# CCXT_BINANCE_API_KEY=
# CCXT_BINANCE_API_SECRET=
# CCXT_BINANCE_API_PASSWORD=

# Interactive Brokers (TWS / Gateway) connectivity.
# Configure these values to point at your running TWS instance. ``IB_HOST``
# and ``IB_PORT`` default to the standard paper-trading gateway port.
IB_HOST=ibkr-gateway.quanttrad
IB_PORT=7497
IB_CLIENT_ID=1

# Optional defaults for contract resolution. These can be overridden on a
# per-request basis using the datasource/exchange inputs or by providing
# explicit contract JSON in ``IB_SYMBOL_OVERRIDES``.
IB_DEFAULT_EXCHANGE=SMART
IB_DEFAULT_SEC_TYPE=STK
IB_DEFAULT_CURRENCY=USD
# IB_SYMBOL_OVERRIDES={"CL": {"secType": "FUT", "exchange": "NYMEX", "lastTradeDateOrContractMonth": "202406"}}
# IB_WHAT_TO_SHOW=TRADES

# Credentials used by the optional Interactive Brokers Gateway container defined
# in ``docker/docker-compose.yml``. Uncomment and fill these values if you want
# Docker to launch and manage the IBKR paper/live gateway for you.
#IBKR_TWS_USERNAME=
#IBKR_TWS_PASSWORD=
#IBKR_TRADING_MODE=paper
#IBKR_TWS_VERSION=latest
#IBKR_LOG_LEVEL=info
#IBKR_GATEWAY_PORT=7497
