# Copy this file to `secrets.env` and fill in the values you actually need.
# `secrets.env` is git-ignored and is loaded by the Docker stack plus some local tooling.
#
# This file is intentionally broader than pure "secrets": it also documents the
# operational env vars most commonly overridden for local runtime behavior.
#
# Infrastructure rule: use `PG_DSN` as the single database DSN. Do not add
# extra DSN variables.

###############################################################################
# Core platform / logging
###############################################################################

DEBUG=true
ENV=dev
PORTAL_LOG_LEVEL=INFO

# Optional comma-separated list for local browser access when not using the
# default Vite proxy setup.
# PORTAL_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional Loki push endpoint for structured logs.
# LOKI_URL=http://loki:3100

###############################################################################
# Database / storage
###############################################################################

# In Docker compose this is usually injected automatically. Set it explicitly if
# you run services outside the compose stack.
# PG_DSN=postgresql+psycopg2://<user>:<password>@localhost:15432/<database>
# POSTGRES_DB=<database>
# POSTGRES_USER=<user>
# POSTGRES_PASSWORD=replace-with-a-local-db-password
# PGADMIN_DEFAULT_PASSWORD=replace-with-a-local-pgadmin-password
# GF_SECURITY_ADMIN_PASSWORD=replace-with-a-local-grafana-password

# Optional DB metadata / behavior.
# PG_APPLICATION_NAME=quant_trad_portal
# PORTAL_DB_WRITE_RETRY_ATTEMPTS=2

# Optional table overrides. Leave these alone unless you know why you are
# changing them.
# CANDLES_RAW_TABLE=market_candles_raw
# CANDLE_STATS_TABLE=candle_stats
# REGIME_STATS_TABLE=regime_stats
# REGIME_BLOCKS_TABLE=regime_blocks
# DERIVATIVES_STATE_TABLE=derivatives_market_state
# CANDLE_CLOSURES_TABLE=portal_candle_closures
# HISTORY_SEGMENT_POINTS=1000

###############################################################################
# Alpaca
###############################################################################

ALPACA_API_KEY=replace-with-your-key
ALPACA_SECRET_KEY=replace-with-your-secret
ALPACA_PAPER=true

###############################################################################
# CCXT / crypto venues
###############################################################################

# Global CCXT credentials. You can also set per-exchange overrides like
# `CCXT_BINANCE_API_KEY`.
CCXT_API_KEY=
CCXT_API_SECRET=
CCXT_PASSWORD=

# Optional behavior flags.
# CCXT_SANDBOX_MODE=false
# CCXT_OHLCV_LIMIT=1000

# Per-exchange overrides (uncomment as needed)
# CCXT_BINANCE_API_KEY=
# CCXT_BINANCE_API_SECRET=
# CCXT_BINANCE_API_PASSWORD=
# CCXT_COINBASE_API_KEY=
# CCXT_COINBASE_API_SECRET=
# CCXT_COINBASE_API_PASSWORD=
# CCXT_KRAKEN_API_KEY=
# CCXT_KRAKEN_API_SECRET=
# CCXT_KRAKEN_API_PASSWORD=

###############################################################################
# Interactive Brokers provider connectivity
###############################################################################

IB_HOST=ibkr-gateway.quanttrad
IB_PORT=4002
IB_CLIENT_ID=1

IB_DEFAULT_EXCHANGE=SMART
IB_DEFAULT_SEC_TYPE=STK
IB_DEFAULT_CURRENCY=USD

# Optional contract/provider overrides.
# IB_WHAT_TO_SHOW=TRADES
# IB_SYMBOL_OVERRIDES={"CL":{"secType":"FUT","exchange":"NYMEX","lastTradeDateOrContractMonth":"202406"}}

###############################################################################
# Managed IBKR gateway container
###############################################################################

# Fill these only if you want Docker to launch and manage the gateway container.
# IBKR_TWS_USERNAME=
# IBKR_TWS_PASSWORD=
# IBKR_TRADING_MODE=paper
# IBKR_LOG_LEVEL=info
# IBKR_READONLY_API=yes
# IBKR_ACCEPT_INCOMING_ACTION=accept
# IBKR_EXISTING_SESSION_ACTION=primary

# Optional gateway port overrides.
# IBKR_GATEWAY_PORT=4002
# IBKR_GATEWAY_LIVE_PORT=4001

# Optional build-time overrides. These should match the current compose defaults
# unless you are pinning/testing a specific gateway or IBC version.
# IBKR_IBC_VERSION=3.23.0
# IBKR_IBC_DOWNLOAD_URL=https://github.com/IbcAlpha/IBC/releases/download/3.23.0/IBCLinux-3.23.0.zip
# IBKR_GATEWAY_VERSION=1037
# IBKR_GATEWAY_DOWNLOAD_URL=https://download2.interactivebrokers.com/installers/ibgateway/stable-standalone/ibgateway-stable-standalone-linux-x64.sh

###############################################################################
# Backend process / worker tuning
###############################################################################

# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000
# QUANTLAB_WORKER_PROCESSES=3
# STATS_WORKER_PROCESSES=2

# QuantLab worker tuning.
# QUANTLAB_WORKER_IDLE_SLEEP_SECONDS=0.2
# QUANTLAB_WORKER_DB_WAIT_TIMEOUT_SECONDS=120
# QUANTLAB_JOB_WAIT_TIMEOUT_SECONDS=180
# QUANTLAB_JOB_POLL_INTERVAL_SECONDS=0.2

# Stats worker tuning.
# STATS_WORKER_IDLE_SLEEP_SECONDS=0.25
# STATS_WORKER_DB_WAIT_TIMEOUT_SECONDS=120

# Async job repository.
# ASYNC_JOB_RUNNING_TIMEOUT_SECONDS=1800

###############################################################################
# Bot runtime / container orchestration
###############################################################################

# Bot runtime supervisor mode.
# BOT_RUNTIME_TARGET=docker

# Compose normally injects these. Override only if your runtime network/image
# names differ.
# BOT_RUNTIME_IMAGE=quanttrad-backend:dev
# BOT_RUNTIME_NETWORK=quant-trad_quanttrad

# Telemetry ingest endpoint used by runtime containers to push BotLens/runtime
# snapshots back into the backend.
# BACKEND_TELEMETRY_WS_URL=ws://backend.quanttrad:8000/api/bots/ws/telemetry/ingest

# Optional credential key propagated into runtime containers for provider access.
# PROVIDER_CREDENTIAL_KEY=

# Bot defaults shown in the portal when creating bots.
# BOT_DEFAULT_SNAPSHOT_INTERVAL_MS=250
# BOT_DEFAULT_SNAPSHOT_FAST_INTERVAL_MS=250
# BOT_DEFAULT_SNAPSHOT_IDLE_INTERVAL_MS=1000
# BOT_DEFAULT_SNAPSHOT_IDLE_CYCLES=2
# BOT_DEFAULT_RUNTIME_PUSH_PAYLOAD_BYTES_SAMPLE_EVERY=10

# Runtime limits / lifecycle tuning.
# BOT_MAX_SYMBOLS_PER_STRATEGY=64
# BOT_SYMBOL_PROCESS_MAX=8
# BOT_STATUS_HEARTBEAT_STALE_MS=45000

###############################################################################
# Bot watchdog / ownership
###############################################################################

# Optional explicit runner identity. If unset, the watchdog derives one from the
# host/container environment.
# BOT_RUNNER_ID=
# BOT_WATCHDOG_HEARTBEAT_INTERVAL=15
# BOT_WATCHDOG_STALE_THRESHOLD=60
# BOT_WATCHDOG_MONITOR_INTERVAL=30

###############################################################################
# BotLens / runtime stream shaping
###############################################################################

# Payload shaping inside the bot runtime container.
# BOT_RUNTIME_PUSH_PAYLOAD_BYTES_SAMPLE_EVERY=10
# BOTLENS_STREAM_MAX_SERIES=12
# BOTLENS_STREAM_MAX_CANDLES=320
# BOTLENS_STREAM_MAX_OVERLAYS=400
# BOTLENS_STREAM_MAX_OVERLAY_POINTS=160
# BOTLENS_STREAM_MAX_CLOSED_TRADES=240
# BOTLENS_STREAM_MAX_LOGS=300
# BOTLENS_STREAM_MAX_DECISIONS=600
# BOTLENS_STREAM_MAX_WARNINGS=120

# Runtime step-trace buffering.
# BOT_RUNTIME_STEP_TRACE_QUEUE_MAX=8192
# BOT_RUNTIME_STEP_TRACE_BATCH_SIZE=200
# BOT_RUNTIME_STEP_TRACE_FLUSH_INTERVAL_MS=200
# BOT_RUNTIME_STEP_TRACE_OVERFLOW_POLICY=drop_oldest

# Frontend-only local tuning. These are normally set in frontend env, but they
# are documented here because BotLens behavior often gets tuned alongside the
# runtime.
# VITE_BOTLENS_DEBUG=true
# VITE_BOTLENS_TARGET_RENDER_LAG_MS=120
# VITE_BOTLENS_CATCHUP_RENDER_LAG_MS=1200
# VITE_BOTLENS_CATCHUP_SEQ_BEHIND=6
# VITE_BOTLENS_CATCHUP_QUEUE_DEPTH=8
# VITE_BOTLENS_NORMAL_APPLY_INTERVAL_MS=33
# VITE_BOTLENS_CATCHUP_APPLY_INTERVAL_MS=12
# VITE_BOTLENS_MAX_CATCHUP_BATCH=2
# VITE_BOTLENS_METRICS_PUBLISH_MS=120
# VITE_BOTLENS_SNAP_CANDLES_BEHIND=30
# VITE_BOTLENS_LEDGER_POLL_MS=800
# VITE_BOTLENS_LEDGER_POLL_LIMIT=500
# VITE_BOTLENS_AUTO_FIT_OVERLAY_EXTENTS=

###############################################################################
# Performance / instrumentation
###############################################################################

# OBS_ENABLED=false
# OBS_STEP_SAMPLE_RATE=1.0
# OBS_SLOW_MS=50
# OBS_LOG_THROTTLE_SECONDS=5

###############################################################################
# Release / integrations
###############################################################################

NOTION_TOKEN=
NOTION_RELEASE_DB_ID=

# Optional automation integration used by the Notion -> Mastodon release flow.
# MASTODON_BASE_URL=https://mastodon.social
# MASTODON_ACCESS_TOKEN=
