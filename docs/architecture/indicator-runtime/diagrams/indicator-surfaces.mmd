flowchart TD
    state["Indicator-owned state"]
    apply["apply_bar(bar, inputs)"]
    snapshot["snapshot()<br/>typed outputs"]
    overlays["overlay_snapshot()<br/>chart projection"]
    details["detail_snapshot()<br/>debug projection"]
    decision["Decision layer"]
    chart["BotLens / charts"]
