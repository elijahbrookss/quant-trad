  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "How To Use",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "Use this dashboard for fast error triage from Loki.\n\n- `stream`: Loki label selector (default `{service=~\".+\"}` for all services)\n- `error_re`: what counts as an error\n- `contains`: optional free-text filter\n\nExamples for `stream`: `{service=\"backend\"}` or `{service=~\"backend|worker\"}`\n\nNote: avoid empty-compatible regex label matchers like `app=~\".*\"`; use `.+` when you mean \"any non-empty value\"."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Errors (Range)",
      "description": "Total matching error logs in selected time range.",
      "datasource": {
        "type": "loki",
        "uid": "quanttrad-loki"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time($stream |~ \"$error_re\" |~ \"$contains\" [$__range]))",
          "queryType": "range",
          "editorMode": "code"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors / Min (5m Avg)",
      "description": "Current average error rate over the last 5 minutes.",
      "datasource": {
        "type": "loki",
        "uid": "quanttrad-loki"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate($stream |~ \"$error_re\" |~ \"$contains\" [5m])) * 60",
          "queryType": "range",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Distinct Error Streams",
      "description": "How many unique streams are currently emitting matched errors.",
      "datasource": {
        "type": "loki",
        "uid": "quanttrad-loki"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (service) (count_over_time($stream |~ \"$error_re\" |~ \"$contains\" [$__range])))",
          "queryType": "range",
          "editorMode": "code"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Errors Over Time (By Service)",
      "datasource": {
        "type": "loki",
        "uid": "quanttrad-loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (count_over_time($stream |~ \"$error_re\" |~ \"$contains\" [$__interval]))",
          "queryType": "range",
          "editorMode": "code",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors Over Time (By Event)",
      "description": "Requires structured `event` field in logfmt logs.",
      "datasource": {
        "type": "loki",
        "uid": "quanttrad-loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk($topn, sum by (event) (count_over_time($stream | logfmt | event!=\"\" |~ \"$error_re\" |~ \"$contains\" [$__interval])))",
          "queryType": "range",
          "editorMode": "code",
          "legendFormat": "{{event}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
