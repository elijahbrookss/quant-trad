    {
      "id": 9,
      "type": "logs",
      "title": "Raw Error Logs",
      "description": "Primary deep-dive surface. Filter with variables and click into log details.",
      "datasource": {
        "type": "loki",
        "uid": "quanttrad-loki"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "$stream |~ \"$error_re\" |~ \"$contains\"",
          "queryType": "range",
          "editorMode": "code"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
